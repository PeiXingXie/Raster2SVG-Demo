# Fill these before the first real model-backed conversion.
API_KEY=your-api-key
BASE_URL=https://your-openai-compatible-endpoint.example/v1
API_PROVIDER=openai_compatible
API_FORMAT=openai_chat_completions
MAX_RETRIES=2

AGENT_MODEL=your-coordinator-model
SUBAGENT_MODEL=your-worker-model
AGENT_NAME=raster-svg-coordinator
USE_PREVIOUS_RESPONSE_ID=false

APP_HOST=127.0.0.1
APP_PORT=8120
PORT_PROMPT_TIMEOUT_SECONDS=15
REQUIRE_APPROVAL_FOR_TASK_CREATION=false
RUN_ARTIFACTS_DIR=artifacts/runs

DEFAULT_USER_INPUT=convert this image into SVG format.
MAX_RETRY=4
MAX_BUDGET=80
REGION_PROCESSING_MODE=parallel
REGION_CONCURRENCY=8
WORKFLOW_MODE=region_object
RECOGNITION_BBOX_REFINE_MODE=llm
SAM_PROVIDER_MODE=remote
SAM_REMOTE_URL=
SAM_ENABLED=false
SAM_FALLBACK_TO_LLM=true
SUPERVISOR_MEMORY_ENABLED=false
SUPERVISOR_MEMORY_PERSIST_ENABLED=true
STRATEGY_ENABLED=true

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=raster-to-svg-agent-demo
