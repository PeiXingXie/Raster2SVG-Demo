# API and models
# Fill these before the first real model-backed conversion.
API_KEY=your-api-key
BASE_URL=https://your-openai-compatible-endpoint.example/v1
API_PROVIDER=openai_compatible
API_FORMAT=openai_chat_completions
AGENT_MODEL=gpt-5.5
SUBAGENT_MODEL=gpt-5.5
AGENT_NAME=raster-svg-coordinator
USE_PREVIOUS_RESPONSE_ID=false

# Local service and artifact storage
# Local-only service binding. Non-loopback addresses are rejected.
APP_HOST=127.0.0.1
APP_PORT=8120
PORT_PROMPT_TIMEOUT_SECONDS=15
REQUIRE_APPROVAL_FOR_TASK_CREATION=false
RUN_ARTIFACTS_DIR=artifacts/runs

DEFAULT_USER_INPUT=convert this image into SVG format.

# User-facing quality and budget defaults
# These values may be overridden from Desktop Settings.
RUN_MODEL_CALL_BUDGET=80
BBOX_REFINEMENT_MAX_ROUNDS=4
REGION_REPAIR_MAX_ATTEMPTS=4
OBJECT_REPAIR_MAX_ATTEMPTS=4
FUSION_REPAIR_MAX_ATTEMPTS=3

# Internal retry and validation policy
# These reliability controls are intentionally not exposed in Desktop Settings.
TRANSPORT_MAX_ATTEMPTS=3
RESPONSE_VALIDATION_MAX_ATTEMPTS=3
BBOX_INITIAL_LOCALIZATION_MAX_ATTEMPTS=2
BBOX_GLOBAL_STAGNATION_MAX_ROUNDS=2
FIDELITY_VERIFICATION_MAX_ATTEMPTS=2
FIDELITY_VERIFICATION_INDEPENDENT_BUDGET=true

# Processing and concurrency
REGION_PROCESSING_MODE=parallel
REGION_CONCURRENCY=8
# Shared cap across all concurrently running conversions.
SHAPE_STUDIO_MODEL_CALL_CONCURRENCY=8
# Queue capacity is process-local. Run the API with one Uvicorn worker.
SHAPE_STUDIO_MAX_QUEUED_RUNS=12
# Manual refinements use a separate bounded executor.
SHAPE_STUDIO_MANUAL_ADJUSTMENT_WORKERS=2
SHAPE_STUDIO_MAX_QUEUED_MANUAL_ADJUSTMENTS=6
WORKFLOW_MODE=region_object

# Recognition provider
RECOGNITION_BBOX_REFINE_MODE=llm
SAM_PROVIDER_MODE=remote
SAM_REMOTE_URL=
SAM_ENABLED=false
SAM_FALLBACK_TO_LLM=true

# Supervisor behavior
SUPERVISOR_MEMORY_ENABLED=false
SUPERVISOR_MEMORY_PERSIST_ENABLED=true
STRATEGY_ENABLED=true

# Observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=raster-to-svg-agent-demo

# Deprecated aggregate retry settings (kept as migration reference only)
# MAX_RETRIES=2
# MAX_RETRY=4
# FUSION_MAX_RETRY=3
# MAX_BUDGET=80
# BBOX_GLOBAL_STAGNATION_ROUNDS=2
# BBOX_ISSUE_STAGNATION_ROUNDS=3
